@startuml overall_architecture
title RANAL - Architektura systému (zobecněná verze)

skinparam shadowing false
skinparam componentStyle rectangle
skinparam linetype ortho

' Větší mezery pro lepší prodyšnost diagramu
skinparam nodesep 60
skinparam ranksep 80

actor "Uživatel" as user

' Externí zdroje nad backendem
cloud "GitHub API" as gh
folder "Lokální git mirror" as repo
component "Frontend\n(SPA / dashboard)" as fe

package "RANAL Backend (Rust, modulární monolit)" as be {
  
  component "Prezentační vrstva\n(REST API + OpenAPI docs)" as api
  component "Vstupní vrstva\n(ingest, sync trigger, validace)" as input
  
  component "Agregační vrstva\n(transformace, business pravidla, backfill)" as agg
  component "Úložná vrstva\n(repozitáře, transakce, SQL dotazy)" as store
  
  ' Skryté vazby pro uspořádání vrstev pod sebou
  api -[hidden]down-> agg
  input -[hidden]down-> agg
  agg -[hidden]down-> store
}

database "PostgreSQL" as db
artifact "Logy / monitoring" as logs

' ==========================================
' Vazby a tok dat 
' ==========================================

user --> fe : práce s aplikací

fe ---> api : HTTP REST\n(dotazy na data)

gh ---> input : poskytuje\nPR/issues/users
repo ---> input : poskytuje\nhistorii a diffy

input --> agg : předání\nsurových dat
api ---> store : čtení /\nagregované dotazy

agg --> store : uložení\nnormalizovaných událostí


store ---> db : SELECT / INSERT / UPDATE


agg ----> logs : metriky + chyby\n+ trvání
api ---> logs : request /\nerror logy

note top of be
  Backend je jeden deployable celek
  s interním dělením do vrstev.
end note

@enduml