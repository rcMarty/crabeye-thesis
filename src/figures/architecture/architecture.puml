@startuml name
title RANAL - Detailni architektura systemu (modularni monolit + frontend)

left to right direction
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultFontName Monospace
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #F8F9FA
  BorderColor #495057
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #6C757D
}
skinparam database {
  BackgroundColor #FFF3CD
  BorderColor #856404
}
skinparam cloud {
  BackgroundColor #E7F5FF
  BorderColor #1C7ED6
}
skinparam folder {
  BackgroundColor #F1F3F5
  BorderColor #868E96
}

actor "Uzivatel" as user
node "Frontend klient\n(Web SPA / dashboard)" as fe
cloud "GitHub API" as gh

package "RANAL Backend (Rust)" as backend {
  component "Entry point\n`src/main.rs`" as main
  component "Commands / runtime rezimy\n`src/commands.rs`" as commands
  component "Config\n`src/config.rs`" as config

  package "API vrstva (`src/api/*`)" as api_layer {
    component "Router\n`src/api/mod.rs`" as api_router
    component "Issues endpointy\n`src/api/issues.rs`" as api_issues
    component "PR/Review endpointy\n`src/api/review.rs`" as api_review
    component "Webhooks endpointy\n`src/api/webhooks.rs`" as api_webhooks
    component "OpenAPI/Docs\n`src/api/docs.rs`" as api_docs
    component "AppState\n`src/api/app_state.rs`" as app_state
  }

  package "Agregacni / integračni vrstva (`src/git/*`)" as agg_layer {
    component "SyncHandler\n`src/git/mod.rs`" as sync_handler
    component "GitHubApi klient\n`src/git/github.rs`" as github_client
    component "Repo adapter (git2)\n`src/git/git.rs`" as repo_adapter
  }

  package "Ulozna vrstva (`src/db/*`)" as db_layer {
    component "Database facade\n`src/db/mod.rs`" as db_facade
    component "Queries\n`src/db/queries.rs`" as db_queries
    component "Inserts/Upserts\n`src/db/inserts.rs`" as db_inserts
    component "Modely\n`src/db/model/*`" as db_models
  }

  package "Monitoring (`src/monitoring/*`)" as mon_layer {
    component "StateMonitor\n`src/monitoring/state_tracker.rs`" as state_monitor
  }
}

database "SQL DB\n(schema + indexy)" as sql_db
folder "Migrace\n`migrations/*.sql`" as migrations
folder "Lokalni mirror repozitare\n`./test_repos/<repo>`" as local_repo
artifact "Aplikacni logy\n`*.log`" as logs
node "Docker Compose runtime\n`docker-compose.yml`" as compose

' ==== Hlavni interakce (prezentace) ====
user --> fe : interakce v UI
fe --> api_router : HTTP(S) REST/JSON\n(GET endpointy, pagination, filtry)
api_router --> api_issues : routovani issues dotazu
api_router --> api_review : routovani PR/review dotazu
api_router --> api_webhooks : webhook prijem
api_router --> api_docs : docs UI/spec
api_issues --> app_state
api_review --> app_state
api_webhooks --> app_state

' ==== API -> DB ====
app_state --> db_facade : volani DB metod
db_facade --> db_queries : cteni/agregace
db_facade --> db_inserts : zapis/upsert/historie
db_queries --> db_models
db_inserts --> db_models
db_queries --> sql_db : SELECT / JOIN / GROUP BY
db_inserts --> sql_db : INSERT / UPSERT / TX

' ==== Sync pipeline ====
commands --> sync_handler : spusteni sync rezimu
main --> commands
config --> commands : repo, owner, token, DB
state_monitor --> sync_handler : periodicky sync/backfill

sync_handler --> github_client : fetch users/PR/issues/timeline
github_client --> gh : GitHub REST API

sync_handler --> repo_adapter : modified_files(merge_sha)
repo_adapter --> local_repo : cteni commitu/stromu

sync_handler --> db_facade : insert PR/issues/file_activity/history
sync_handler --> logs : info/warn/error + duration
state_monitor --> logs
api_router --> logs

migrations --> sql_db : aplikace schematu + indexu
compose --> backend : orchestruje sluzbu
compose --> sql_db : orchestruje DB

note right of sync_handler
  Orchestrace:
  1) users -> upsert_team_members
  2) PR sync (+ file_activity)
  3) issues sync
  4) backfill missing history
end note

note bottom of api_router
  Frontend je tenky klient:
  - vola API
  - vykresluje data
  - business logika zustava v backendu
end note
@enduml
