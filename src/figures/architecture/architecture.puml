@startuml detailed_architecture
title Detailní architektura systému (modulární monolit)

' === Základní nastavení vzhledu ===
skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultFontName Monospace
skinparam linetype ortho

' Výrazné zvětšení mezer pro velký diagram v příloze
skinparam nodesep 40
skinparam ranksep 60
skinparam padding 2

' === Barvy ===
skinparam rectangle {
  BackgroundColor #F8F9FA
  BorderColor #495057
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #6C757D
}
skinparam database {
  BackgroundColor #FFF3CD
  BorderColor #856404
}
skinparam cloud {
  BackgroundColor #E7F5FF
  BorderColor #1C7ED6
}
skinparam folder {
  BackgroundColor #F1F3F5
  BorderColor #868E96
}

' === Externí aktéři a frontend ===
actor "Uživatel" as user
node "Frontend klient\n(Web SPA / Vue dashboard)" as fe

note right of fe
  Tenký klient:
  - volá REST API
  - vykresluje data a grafy
  - business logika je v backendu
end note

' === BACKEND ===
package "Backend (Rust)" as backend {
  
  package "Vstup a Konfigurace" as config_layer {
    component "Config\n`src/config.rs`" as config
    component "Entry point\n`src/main.rs`" as main
    component "Commands / režimy\n`src/commands.rs`" as commands
    
    config -[hidden]right-> main
    main -down-> commands
    config -down-> commands
  }

  package "API vrstva (`src/api/*`)" as api_layer {
    component "Router\n`src/api/mod.rs`" as api_router
    component "OpenAPI/Docs\n`src/api/docs.rs`" as api_docs
    
    component "Issues endpointy\n`src/api/issues.rs`" as api_issues
    component "PR/Review endpointy\n`src/api/review.rs`" as api_review
    component "AppState\n`src/api/app_state.rs`" as app_state
    
    api_router -down-> api_issues
    api_router -down-> api_review
    api_router -right-> api_docs
    api_router -down-> app_state : " sdílený stav"
    
    api_issues -down-> app_state
    api_review -down-> app_state
  }

  package "Agregační / integrační vrstva (`src/git/*`)" as agg_layer {
    component "StateMonitor\n`src/monitoring/state_tracker.rs`" as state_monitor
    component "SyncHandler\n`src/git/mod.rs`" as sync_handler
    component "GitHubApi klient\n`src/git/github.rs`" as github_client
    component "Repo adaptér (git2)\n`src/git/git.rs`" as repo_adapter
    
    state_monitor -down-> sync_handler : periodický\nsync/backfill
    sync_handler -down-> github_client
    sync_handler -down-> repo_adapter
  }

  package "Úložná vrstva (`src/db/*`)" as db_layer {
    component "Database facade\n`src/db/mod.rs`" as db_facade
    component "Queries (Čtení)\n`src/db/queries.rs`" as db_queries
    component "Inserts (Zápis)\n`src/db/inserts.rs`" as db_inserts
    component "Modely\n`src/db/model/*`" as db_models
    
    db_facade -down-> db_queries
    db_facade -down-> db_inserts
    db_queries -down-> db_models
    db_inserts -down-> db_models
  }
}

' === Infrastruktura a Externí zdroje ===
cloud "GitHub REST API" as gh
folder "Lokální mirror repozitáře\n`./test_repos/<repo>`" as local_repo

database "SQL Databáze\n(schéma + indexy)" as sql_db
artifact "Aplikační logy\n`*.log`" as logs

together {
  node "Docker Compose runtime" as compose
  folder "Migrace\n`migrations/*.sql`" as migrations
}

' === VAZBY A ŠIPKY ===

user -down-> fe : interakce v UI
fe -down-> api_router : HTTP(S) REST/JSON

' Vazba mezi vrstvami v backendu
app_state -down-> db_facade : volání\nmetod nad DB
commands -down-> sync_handler : spuštění\nsync režimu
sync_handler -down-> db_facade : insert\nPR/issues/history

note right of sync_handler
  Orchestrace:
  1) users -> upsert_team_members
  2) PR sync (+ file_activity)
  3) issues sync
  4) backfill chybějící historie
end note

' Externí data
github_client -down-> gh : fetch\nusers/PR/issues
repo_adapter -down-> local_repo : čtení\ncommitů/stromů

' DB vazby
db_queries -down-> sql_db : SELECT / JOIN\n/ GROUP BY
db_inserts -down-> sql_db : INSERT / UPSERT\n/ TX

' Logování (vedeno mimo hlavní osu)
sync_handler -right-> logs : info/error\n+ trvání
api_router -left-> logs : request logs

' Infrastruktura
compose -up-> main : orchestruje\nslužbu
compose -right-> sql_db : orchestruje DB
migrations ----left---> sql_db : aplikace\nschématu

' Pomocné skryté vazby pro layout
config_layer -[hidden]down-> api_layer
api_layer -[hidden]down-> agg_layer
agg_layer -[hidden]down-> db_layer

@enduml